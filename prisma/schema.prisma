generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String   @id @default(cuid())
  businessName String?
  name         String?
  email        String
  phone        String?
  service      String?
  message      String?
  source       String?  @default("website")
  createdAt    DateTime @default(now())
}
